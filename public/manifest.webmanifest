      "sizes": "780x1688",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "JSON Formatter on mobile (dark theme)"
    },
    {
      "src": "/screenshots/emi-calculator-dark-wide.png",
      "sizes": "2560x1600",
      "type": "image/png",
