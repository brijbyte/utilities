{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "utilities",
  "compatibility_date": "2025-03-01",
  "pages_build_output_dir": "dist",
  "assets": {
    "directory": "dist",
  },
  "routes": [
    {
      "pattern": "utilities.brijbyte.com",
      "custom_domain": true,
    },
  ],
}
